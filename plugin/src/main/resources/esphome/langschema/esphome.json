      "delay": {
        "schema": {
          "extends": [
            "core.positive_time_period_milliseconds"
          ]
        },
        "templatable": true,
        "type": "schema"
      },
      "if": {
        "schema": {
          "config_vars": {
            "all": {
              "key": "Optional",
              "registry": "condition",
              "type": "registry"
            },
            "any": {
              "key": "Optional"
            },
            "condition": {
              "key": "Optional",
              "registry": "condition",
              "type": "registry"
            },
            "else": {
              "is_list": true,
              "key": "Optional",
              "registry": "action",
              "type": "registry"
            },
            "then": {
              "is_list": true,
              "key": "Optional",
              "registry": "action",
              "type": "registry"
            }
          }
        },
        "type": "schema"
      },
      "lambda": {},
