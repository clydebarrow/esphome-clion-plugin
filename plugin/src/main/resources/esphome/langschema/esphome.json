      "COMPONENT_SCHEMA": {
        "schema": {
          "config_vars": {
            "setup_priority": {
              "key": "Optional",
              "visibility": "yaml_only"
            }
          }
        },
        "type": "schema"
      },
      "ENTITY_BASE_SCHEMA": {
        "schema": {
          "config_vars": {
            "device_id": {
              "key": "Optional",
              "schema": {},
              "type": "use_id",
              "use_id_type": "Device"
            },
            "disabled_by_default": {
              "default": "False",
              "key": "Optional",
              "type": "boolean"
            },
            "entity_category": {
              "key": "Optional"
            },
            "icon": {
              "key": "Optional"
            },
            "internal": {
              "key": "Optional",
              "type": "boolean"
            },
            "name": {
              "key": "Optional"
            }
          }
        },
        "type": "schema"
      },
      "GIT_SCHEMA": {
        "schema": {
          "config_vars": {
            "password": {
              "key": "Optional",
              "sensitive": true,
              "sensitive_source": "heuristic",
              "type": "string"
            },
            "path": {
              "key": "Optional",
              "type": "string"
            },
            "ref": {
              "key": "Optional"
            },
            "url": {
              "key": "Required"
            },
            "username": {
              "key": "Optional",
              "type": "string"
            }
          }
        },
        "type": "schema"
      },
      "MQTT_COMMAND_COMPONENT_SCHEMA": {
        "schema": {
          "config_vars": {
            "command_retain": {
              "key": "Optional",
              "type": "boolean"
            },
            "command_topic": {
              "key": "Optional",
              "templatable": true
            }
          },
          "extends": [
            "core.MQTT_COMPONENT_SCHEMA"
          ]
        },
        "type": "schema"
      },
      "MQTT_COMPONENT_SCHEMA": {
        "schema": {
          "config_vars": {
            "availability": {
              "key": "Optional",
              "schema": {
                "config_vars": {
                  "payload_available": {
                    "default": "online",
                    "key": "Optional"
                  },
                  "payload_not_available": {
                    "default": "offline",
                    "key": "Optional"
                  },
                  "topic": {
                    "key": "Required"
                  }
                }
              },
              "type": "schema"
            },
            "discovery": {
              "key": "Optional",
              "type": "boolean"
            },
            "qos": {
              "key": "Optional"
            },
            "retain": {
              "key": "Optional",
