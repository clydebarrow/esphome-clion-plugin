                ]
              },
              "templatable": true,
              "type": "schema"
            }
          }
        },
        "type": "schema"
      },
      "while": {
        "schema": {
          "config_vars": {
            "condition": {
              "key": "Required",
              "registry": "condition",
              "type": "registry"
            },
            "then": {
              "is_list": true,
              "key": "Required",
              "registry": "action",
              "type": "registry"
            }
          }
