<idea-plugin>
    <!-- Plugin ID must not contain a JetBrains product name (e.g. "clion"),
         per Marketplace rules; the io.esphome.clion.* Kotlin packages are
         unaffected. The ID is permanent once published. -->
    <id>io.esphome.plugin</id>
    <name>ESPHome</name>
    <vendor email="clyde@stubbs.me" url="https://esphome.io">Clyde Stubbs</vendor>

    <description><![CDATA[
        <p>ESPHome support for JetBrains IDEs: context-aware completion, hover
        documentation, live validation, and navigation for ESPHome YAML device
        configurations — driven by the ESPHome component catalog.</p>
        <p>Also: compile / run / flash run configurations, and a live device tool
        window showing a running device's entities over the native API.</p>
        <p>Documentation &amp; screenshots:
        <a href="https://clydebarrow.github.io/esphome-clion-plugin/">clydebarrow.github.io/esphome-clion-plugin</a></p>
    ]]></description>

    <!-- YAML PSI/parsing comes from the bundled YAML plugin (present in CLion). -->
    <depends>com.intellij.modules.platform</depends>
    <depends>org.jetbrains.plugins.yaml</depends>

    <extensions defaultExtensionNs="com.intellij">
        <completion.contributor
            language="yaml"
            implementationClass="io.esphome.clion.completion.EsphomeCompletionContributor"/>

        <externalAnnotator
            language="yaml"
            implementationClass="io.esphome.clion.validation.EsphomeValidationAnnotator"/>

        <!-- Lexer-based highlighting + structural checks for embedded lambdas (C++). -->
        <annotator
            language="yaml"
            implementationClass="io.esphome.clion.lambda.EsphomeLambdaAnnotator"/>

        <lang.documentationProvider
            language="yaml"
            implementationClass="io.esphome.clion.documentation.EsphomeDocumentationProvider"/>

        <psi.referenceContributor
            language="yaml"
            implementation="io.esphome.clion.references.EsphomeIncludeReferenceContributor"/>

        <psi.referenceContributor
            language="yaml"
            implementation="io.esphome.clion.references.EsphomeIdReferenceContributor"/>

        <psi.referenceContributor
            language="yaml"
            implementation="io.esphome.clion.references.EsphomeSubstitutionReferenceContributor"/>

        <psi.referenceContributor
            language="yaml"
            implementation="io.esphome.clion.references.EsphomeSecretReferenceContributor"/>

        <psi.referenceContributor
            language="yaml"
            implementation="io.esphome.clion.references.EsphomeLambdaIdReferenceContributor"/>

        <fileBasedIndex implementation="io.esphome.clion.index.EsphomeIncludeIndex"/>
        <fileBasedIndex implementation="io.esphome.clion.index.EsphomeIdIndex"/>

        <referencesSearch implementation="io.esphome.clion.references.EsphomeIdReferenceSearcher"/>
        <findUsagesHandlerFactory implementation="io.esphome.clion.references.EsphomeIdFindUsagesHandlerFactory"/>
        <usageTargetProvider implementation="io.esphome.clion.references.EsphomeIdUsageTargetProvider"/>
        <targetElementEvaluator
            language="yaml"
            implementationClass="io.esphome.clion.references.EsphomeTargetElementEvaluator"/>
        <renamePsiElementProcessor
            implementation="io.esphome.clion.references.EsphomeIdRenameProcessor"
            order="first"/>
        <renameHandler implementation="io.esphome.clion.references.EsphomeIdRenameHandler"/>

        <applicationConfigurable
            parentId="tools"
            id="io.esphome.clion.settings.EsphomeSettingsConfigurable"
            displayName="ESPHome"
            instance="io.esphome.clion.settings.EsphomeSettingsConfigurable"/>

        <notificationGroup id="ESPHome" displayType="BALLOON"/>

        <localInspection
            language="yaml"
            shortName="EsphomeUnresolvedId"
            displayName="Unresolved ESPHome id reference"
            groupName="ESPHome"
            enabledByDefault="true"
            level="WARNING"
            implementationClass="io.esphome.clion.inspections.EsphomeUnresolvedIdInspection"/>

        <localInspection
            language="yaml"
            shortName="EsphomeUnusedId"
            displayName="Unused ESPHome id"
            groupName="ESPHome"
            enabledByDefault="false"
            level="WEAK WARNING"
            implementationClass="io.esphome.clion.inspections.EsphomeUnusedIdInspection"/>

        <localInspection
            language="yaml"
            shortName="EsphomeUnresolvedSubstitution"
            displayName="Unresolved ESPHome substitution"
            groupName="ESPHome"
            enabledByDefault="true"
            level="WARNING"
            implementationClass="io.esphome.clion.inspections.EsphomeUnresolvedSubstitutionInspection"/>

        <configurationType implementation="io.esphome.clion.run.EsphomeRunConfigurationType"/>
        <runConfigurationProducer
            implementation="io.esphome.clion.run.EsphomeRunConfigurationProducer"/>

        <toolWindow
            id="ESPHome Device"
            anchor="bottom"
            icon="AllIcons.Nodes.Plugin"
            factoryClass="io.esphome.clion.api.toolwindow.EsphomeApiToolWindowFactory"/>

        <!-- Masks values in an open secrets.yaml, revealing the caret's line. -->
        <postStartupActivity implementation="io.esphome.clion.secrets.EsphomeSecretMaskingStartup"/>
    </extensions>

    <applicationListeners>
        <!-- Drop live device connections before the plugin unloads, so a reload
             doesn't require an IDE restart. -->
        <listener
            class="io.esphome.clion.EsphomeDynamicPluginCleanup"
            topic="com.intellij.ide.plugins.DynamicPluginListener"/>
    </applicationListeners>

    <actions>
        <action
            id="io.esphome.clion.api.OpenDeviceWindow"
            class="io.esphome.clion.api.toolwindow.EsphomeOpenDeviceWindowAction"
            text="Open ESPHome Device Window"
            description="Open the ESPHome Device tool window with host and key pre-filled from this config"
            icon="AllIcons.Nodes.Plugin">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
            <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
