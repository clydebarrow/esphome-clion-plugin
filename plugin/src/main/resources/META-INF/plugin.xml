<idea-plugin>
    <!-- Plugin ID must not contain a JetBrains product name (e.g. "clion"),
         per Marketplace rules; the io.esphome.clion.* Kotlin packages are
         unaffected. The ID is permanent once published. -->
    <id>io.esphome.plugin</id>
    <name>ESPHome</name>
    <vendor email="clyde@stubbs.me" url="https://esphome.io">Clyde Stubbs</vendor>

    <description><![CDATA[
        <p>ESPHome configuration support for JetBrains IDEs.</p>
        <p>Provides completion, documentation, validation, and navigation for
        ESPHome YAML device configurations, driven by the ESPHome component
        catalog.</p>
    ]]></description>

    <!-- YAML PSI/parsing comes from the bundled YAML plugin (present in CLion). -->
    <depends>com.intellij.modules.platform</depends>
    <depends>org.jetbrains.plugins.yaml</depends>

    <extensions defaultExtensionNs="com.intellij">
        <completion.contributor
            language="yaml"
            implementationClass="io.esphome.clion.completion.EsphomeCompletionContributor"/>

        <externalAnnotator
            language="yaml"
            implementationClass="io.esphome.clion.validation.EsphomeValidationAnnotator"/>

        <lang.documentationProvider
            language="yaml"
            implementationClass="io.esphome.clion.documentation.EsphomeDocumentationProvider"/>

        <psi.referenceContributor
            language="yaml"
            implementation="io.esphome.clion.references.EsphomeIncludeReferenceContributor"/>

        <psi.referenceContributor
            language="yaml"
            implementation="io.esphome.clion.references.EsphomeIdReferenceContributor"/>

        <psi.referenceContributor
            language="yaml"
            implementation="io.esphome.clion.references.EsphomeSubstitutionReferenceContributor"/>

        <fileBasedIndex implementation="io.esphome.clion.index.EsphomeIncludeIndex"/>
        <fileBasedIndex implementation="io.esphome.clion.index.EsphomeIdIndex"/>

        <referencesSearch implementation="io.esphome.clion.references.EsphomeIdReferenceSearcher"/>
        <findUsagesHandlerFactory implementation="io.esphome.clion.references.EsphomeIdFindUsagesHandlerFactory"/>
        <usageTargetProvider implementation="io.esphome.clion.references.EsphomeIdUsageTargetProvider"/>
        <targetElementEvaluator
            language="yaml"
            implementationClass="io.esphome.clion.references.EsphomeTargetElementEvaluator"/>
        <renamePsiElementProcessor
            implementation="io.esphome.clion.references.EsphomeIdRenameProcessor"
            order="first"/>
        <renameHandler implementation="io.esphome.clion.references.EsphomeIdRenameHandler"/>

        <applicationConfigurable
            parentId="tools"
            id="io.esphome.clion.settings.EsphomeSettingsConfigurable"
            displayName="ESPHome"
            instance="io.esphome.clion.settings.EsphomeSettingsConfigurable"/>

        <notificationGroup id="ESPHome" displayType="BALLOON"/>

        <localInspection
            language="yaml"
            shortName="EsphomeUnresolvedId"
            displayName="Unresolved ESPHome id reference"
            groupName="ESPHome"
            enabledByDefault="true"
            level="WARNING"
            implementationClass="io.esphome.clion.inspections.EsphomeUnresolvedIdInspection"/>

        <localInspection
            language="yaml"
            shortName="EsphomeUnusedId"
            displayName="Unused ESPHome id"
            groupName="ESPHome"
            enabledByDefault="false"
            level="WEAK WARNING"
            implementationClass="io.esphome.clion.inspections.EsphomeUnusedIdInspection"/>

        <localInspection
            language="yaml"
            shortName="EsphomeUnresolvedSubstitution"
            displayName="Unresolved ESPHome substitution"
            groupName="ESPHome"
            enabledByDefault="true"
            level="WARNING"
            implementationClass="io.esphome.clion.inspections.EsphomeUnresolvedSubstitutionInspection"/>
    </extensions>
</idea-plugin>
